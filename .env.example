# Aplicação
APP_NAME=BetGenius
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost:3001
PORT=3001

# Banco de Dados
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=betgenius
DB_USERNAME=root
DB_PASSWORD=

# JWT
JWT_SECRET=betgenius-secret-key-change-in-production-2024
JWT_EXPIRATION=3600

# Redis (opcional)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# PlayFiver (opcional, pode estar no banco)
PLAYFIVER_TOKEN=
PLAYFIVER_SECRET=
PLAYFIVER_CODE=

# Storage
STORAGE_PATH=./storage
STORAGE_URL=http://localhost:3001/storage

# CORS
CORS_ORIGIN=http://localhost:3000
